# Jarvis CLI configuration — copy to `.env` (project-local) or `~/.jarvis/.env`
# (global), then fill in. The CLI loads these automatically at startup, like
# git reading ~/.gitconfig and .git/config. Never commit your real `.env`.
#
# Precedence (highest wins): real environment > ./.env > ~/.jarvis/.env

# Required for the cloud engine: your OpenRouter API key. Not needed when running
# fully local (JARVIS_LLM_PROVIDER=ollama and all roles local).
OPENROUTER_API_KEY=your_openrouter_key_here

# ── Chat engine (LLM provider) ───────────────────────────────────────────────
# Which engine serves the MAIN turn: 'openrouter' (cloud, default) or 'ollama'
# (local, free, private). Also a live toggle in-app: `config set provider ollama`.
# JARVIS_LLM_PROVIDER=openrouter

# Optional per-role overrides. Unset → the role follows the main toggle above.
# Set to pin a role to a fixed engine, e.g. keep the main turn on the cloud while
# running the cheap internal calls locally:
#   JARVIS_UTILITY_PROVIDER  — invariant checks, memory, personalisation
#   JARVIS_SUBAGENT_PROVIDER — pipeline stage agents (planning/execution/validation)
# JARVIS_UTILITY_PROVIDER=ollama
# JARVIS_SUBAGENT_PROVIDER=ollama

# Local chat model for the 'ollama' provider. Pull it first: ollama pull qwen2.5:7b
# JARVIS_OLLAMA_MODEL=qwen2.5:7b

# Optional: URL of the standalone Jarvis MCP server (time, weather digest, and the
# weather-anomaly pipeline get_weather_readings → detect_weather_anomalies →
# send_telegram_alert, namespaced as jarvis.*). Unset → no MCP tools. The legacy
# name JARVIS_TIME_MCP_URL is still honoured for backward compatibility.
JARVIS_MCP_URL=http://localhost:8080/mcp

# Optional: API key sent (as X-API-Key) to the network MCP server once auth is on.
# Leave unset while the server runs without auth (local Inspector testing).
# MCP_API_KEY=your_mcp_server_key_here

# ── Multi-server MCP fleet ───────────────────────────────────────────────────
# To register several MCP servers (network + local stdio) instead of the single
# JARVIS_MCP_URL above, create a servers.json (see servers.json.example) in the
# CWD or ~/.jarvis/, or point this at it. When present it takes precedence and
# JARVIS_MCP_URL/MCP_API_KEY are referenced from inside that file via ${VAR}.
# JARVIS_SERVERS_FILE=/path/to/servers.json

# Required only if the fleet includes the World News MCP server (worldnews):
# a worldnewsapi.com key, launched into the stdio subprocess via ${WORLD_NEWS_API_KEY}.
# WORLD_NEWS_API_KEY=your_world_news_api_key_here

# Translation MCP server (translation): LibreTranslate (free, no API key). The
# servers.json entry sets LIBRETRANSLATE_API_URL to a public instance; override it
# here to use a different instance or a self-hosted one (better quality/reliability).
# LIBRETRANSLATE_API_URL=https://translate.fedilab.app

# ── Document indexing / embeddings (RAG) ─────────────────────────────────────
# Which embedding provider 'index build/search' uses. Default 'ollama' (local,
# free, private — recommended). 'openrouter' uses the cloud endpoint and your
# OPENROUTER_API_KEY (costs money). 'fake' is a deterministic offline embedder.
# JARVIS_EMBED_PROVIDER=ollama

# Embedding model. Defaults per provider: ollama → nomic-embed-text,
# openrouter → openai/text-embedding-3-small.
# JARVIS_EMBED_MODEL=nomic-embed-text

# Base URL of the local Ollama daemon — shared by the 'ollama' chat engine AND the
# 'ollama' embedder. Install: brew install ollama && ollama serve
# JARVIS_OLLAMA_URL=http://localhost:11434
