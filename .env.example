# Jarvis CLI configuration — copy to `.env` (project-local) or `~/.jarvis/.env`
# (global), then fill in. The CLI loads these automatically at startup, like
# git reading ~/.gitconfig and .git/config. Never commit your real `.env`.
#
# Precedence (highest wins): real environment > ./.env > ~/.jarvis/.env

# Required: your OpenRouter API key.
OPENROUTER_API_KEY=your_openrouter_key_here

# Optional: enable the remote/standalone time MCP server. Unset → weather-only.
JARVIS_TIME_MCP_URL=http://localhost:8080/mcp

# Optional: API key sent (as X-API-Key) to network MCP servers once auth is on.
# Leave unset while the local time server runs without auth.
# MCP_API_KEY=your_mcp_server_key_here
