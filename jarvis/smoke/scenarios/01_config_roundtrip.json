{
  "name": "config round-trip: set a value and see it persist in the session",
  "platform": "cli",
  "steps": [
    {"action": "config set temperature 0.7", "expect": "temperature = 0.7"},
    {"action": "config show",                "expect": "Active configuration"},
    {"action": "config show",                "expect": "temperature"}
  ]
}
