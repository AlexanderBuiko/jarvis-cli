{
  "_comment": "Multi-server MCP fleet for jarvis-cli. Copy to ./servers.json or ~/.jarvis/servers.json (or point JARVIS_SERVERS_FILE at it). The agent aggregates every server's tools, namespaced as <name>.<tool>, and routes each call to the owning server. ${VAR} in any string is expanded from the environment, so API keys stay out of this file. The translation server passes its key as a URL query param since our client sends only X-API-Key; swap in any remote translation MCP whose tools the LLM can pick by description.",
  "servers": [
    {
      "name": "jarvis",
      "transport": "streamable-http",
      "url": "${JARVIS_MCP_URL}",
      "api_key_env": "MCP_API_KEY"
    },
    {
      "name": "translation",
      "transport": "streamable-http",
      "url": "https://mcp.doctranslate.io/mcp?api_key=${DOCTRANSLATE_API_KEY}"
    },
    {
      "name": "worldnews",
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "world-news-api-mcp"],
      "env": { "WORLD_NEWS_API_KEY": "${WORLD_NEWS_API_KEY}" }
    }
  ]
}
