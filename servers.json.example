{
  "_comment": "Multi-server MCP fleet for jarvis-cli. Copy to ./servers.json or ~/.jarvis/servers.json (or point JARVIS_SERVERS_FILE at it). The agent aggregates every server's tools, namespaced as <name>.<tool>, and routes each call to the owning server. ${VAR} in any string is expanded from the environment, so API keys stay out of this file. Remove these _comment keys in your real file if you like; they are ignored.",
  "servers": [
    {
      "name": "jarvis",
      "transport": "streamable-http",
      "url": "${JARVIS_MCP_URL}",
      "api_key_env": "MCP_API_KEY"
    },
    {
      "name": "wikipedia",
      "transport": "stdio",
      "command": "wikipedia-mcp",
      "args": []
    },
    {
      "name": "worldnews",
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "world-news-api-mcp"],
      "env": { "WORLD_NEWS_API_KEY": "${WORLD_NEWS_API_KEY}" }
    }
  ]
}
