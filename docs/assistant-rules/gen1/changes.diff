+# ── Notes (free-form user scratch memory) ─────────────────────────────────────
+
+
+def handle_notes_add(args: list[str], store: NotesStore | None = None) -> str:
+    text = " ".join(args).strip()
+    if not text:
+        return "Usage: notes add <text>"
+    note = (store or NotesStore()).add(text)
+    return f"Added note {note.id}."
+
+
+def handle_notes_list(store: NotesStore | None = None) -> str:
+    notes = (store or NotesStore()).list_all()
+    if not notes:
+        return "No notes yet. Use 'notes add <text>' to create one."
+    lines = [f"  {n.id}  {n.created_at[:10]}  {n.text}" for n in notes]
+    return f"Notes ({len(notes)})\n" + "\n".join(lines)
+
+
+def handle_notes_delete(args: list[str], store: NotesStore | None = None) -> str:
+    if not args:
+        return "Usage: notes delete <id>"
+    note_id = args[0]
+    deleted = (store or NotesStore()).delete(note_id)
+    if deleted is None:
+        return f"No single note matches '{note_id}'. Use 'notes list' to see ids."
+    return f"Deleted note {deleted.id}."
+
+
 # ── Profile (system-managed) ──────────────────────────────────────────────────
 
 
