@@ -129,6 +130,13 @@ Commands
   invariants                    Show the global invariants (hard rules)
   invariants init               Scaffold invariants.md from a template
 
+  notes add <text>              Save a note
+  notes list                    List saved notes with their ids
+  notes delete <id>             Delete a note by id
+
+  Notes are plain reminders kept in ~/.jarvis/notes.json. They persist across
+  sessions and are never sent to the model.
+
   profile                       Show the system-managed user profile
   profile onboard               Run (or re-run) the onboarding interview
 
@@ -816,6 +824,34 @@ def handle_invariants_init(agent: JarvisAgent) -> str:
     return f"Scaffolded invariants.md. Edit it directly:\n  {path}"
 
 
+# ── Notes (free-text reminders) ──────────────────────────────────────────────
+
+
+def handle_notes_add(args: list[str], store: NoteStore | None = None) -> str:
+    text = " ".join(args).strip()
+    if not text:
+        return "Usage: notes add <text>"
+    note = (store or NoteStore()).add(text)
+    return f"Saved note {note['id']}."
+
+
+def handle_notes_list(store: NoteStore | None = None) -> str:
+    notes = (store or NoteStore()).list_all()
+    if not notes:
+        return "No notes yet. Use 'notes add <text>' to save one."
+    lines = [f"  {n['id']}  {n['created_at'][:10]}  {n['text']}" for n in notes]
+    return f"Notes ({len(notes)})\n" + "\n".join(lines)
+
+
+def handle_notes_delete(args: list[str], store: NoteStore | None = None) -> str:
+    if not args:
+        return "Usage: notes delete <id>"
+    note_id = args[0]
+    if not (store or NoteStore()).delete(note_id):
+        return f"No note matches '{note_id}'. Use 'notes list' to see the ids."
+    return f"Deleted note {note_id}."
+
+
 # ── Profile (system-managed) ──────────────────────────────────────────────────
 
 
